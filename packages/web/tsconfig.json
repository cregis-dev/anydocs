{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@anydocs/core": [
        "../core/src/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-codex/types/**/*.ts",
    ".next-codex/dev/types/**/*.ts",
    ".next-cli-preview/types/**/*.ts",
    ".next-cli-preview/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "anydocs-desktop",
    "examples",
    "tests",
    "demo",
    "src/app/api"
  ]
}
