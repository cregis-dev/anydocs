{
  "name": "@anydocs/core",
  "version": "1.3.5",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cregis-dev/anydocs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./render-page-content": {
      "types": "./dist/utils/render-page-content.d.ts",
      "import": "./dist/utils/render-page-content.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./runtime-contract": {
      "types": "./runtime-contract.d.ts",
      "import": "./runtime-contract.mjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "runtime-contract.d.ts",
    "runtime-contract.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test --test-concurrency=1 tests/**/*.test.ts"
  },
  "dependencies": {
    "minisearch": "^7.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "typescript": "^5.0.0"
  }
}
