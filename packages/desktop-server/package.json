{
  "name": "@anydocs/desktop-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Anydocs desktop local HTTP server for the Tauri migration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "anydocs-desktop-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anydocs/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
