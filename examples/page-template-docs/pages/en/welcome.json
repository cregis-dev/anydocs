            "type": "text",
            "text": "Page Template Example"
          }
        ]
      },
      {
        "type": "paragraph",
        "id": "block-2",
        "children": [
          {
            "type": "text",
            "text": "This example is focused on Anydocs template behavior instead of the base project skeleton."
          }
        ]
      },
      {
        "type": "heading",
        "id": "block-3",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "When To Use It"
          }
        ]
      },
      {
        "type": "list",
        "id": "block-4",
        "style": "bulleted",
        "items": [
          {
            "id": "element-4-item-1",
            "children": [
              {
                "type": "text",
                "text": "you want to define custom page templates"
              }
            ]
          },
          {
            "id": "element-5-item-1",
            "children": [
              {
                "type": "text",
                "text": "you want to verify how the `template` field binds a page to a template"
              }
            ]
          },
          {
            "id": "element-6-item-1",
            "children": [
              {
                "type": "text",
                "text": "you want to test how `metadataSchema` constrains page metadata"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "id": "block-7",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "What This Example Includes"
          }
        ]
      },
      {
        "type": "list",
        "id": "block-8",
        "style": "bulleted",
        "items": [
          {
            "id": "element-8-item-1",
            "children": [
              {
                "type": "text",
                "text": "`authoring.pageTemplates`"
              }
            ]
          },
          {
            "id": "element-9-item-1",
            "children": [
              {
                "type": "text",
                "text": "a template-backed page called `blueprint-review`"
              }
            ]
          },
          {
            "id": "element-10-item-1",
            "children": [
              {
                "type": "text",
                "text": "sample metadata fields for that template"
              }
            ]
          },
          {
            "id": "element-11-item-1",
            "children": [
              {
                "type": "text",
                "text": "the rendered result of template-backed pages in build / preview"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "id": "block-12",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "How To Run It"
