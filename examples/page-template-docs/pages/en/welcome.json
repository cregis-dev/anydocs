        ]
      },
      {
        "type": "codeBlock",
        "id": "block-13",
        "language": "bash",
        "code": "node --experimental-strip-types packages/cli/src/index.ts build examples/page-template-docs\nnode --experimental-strip-types packages/cli/src/index.ts preview examples/page-template-docs"
      },
      {
        "type": "paragraph",
        "id": "block-14",
        "children": [
          {
            "type": "text",
            "text": "In Studio, select `examples/page-template-docs` as the project path."
