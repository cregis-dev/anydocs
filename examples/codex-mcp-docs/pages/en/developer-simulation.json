  "content": {
    "version": 1,
    "blocks": [
      {
        "type": "heading",
        "id": "block-1",
        "level": 1,
        "children": [
          {
            "type": "text",
            "text": "A Developer Simulation of Building the Site"
          }
        ]
      },
      {
        "type": "paragraph",
        "id": "block-2",
        "children": [
          {
            "type": "text",
            "text": "The demo flow for this project was:"
          }
        ]
      },
      {
        "type": "list",
        "id": "block-3",
        "style": "numbered",
        "items": [
          {
            "id": "element-3-item-1",
            "children": [
              {
                "type": "text",
                "text": "initialize the project with `anydocs init --agent codex`"
              }
            ]
          },
          {
            "id": "element-4-item-1",
            "children": [
              {
                "type": "text",
                "text": "call `project_open` and inspect `project_open.authoring`"
              }
            ]
          },
          {
            "id": "element-5-item-1",
            "children": [
              {
                "type": "text",
                "text": "read `anydocs://authoring/guidance` before multi-step edits"
              }
            ]
          },
          {
            "id": "element-6-item-1",
            "children": [
              {
                "type": "text",
                "text": "update the welcome page with `page_update`"
              }
            ]
          },
          {
            "id": "element-7-item-1",
            "children": [
              {
                "type": "text",
                "text": "create Codex-focused pages with `page_create_from_template` or `page_create`"
              }
            ]
          },
          {
            "id": "element-8-item-1",
            "children": [
              {
                "type": "text",
                "text": "set template metadata only when the selected template's `metadataSchema` allows it"
              }
            ]
          },
          {
            "id": "element-9-item-1",
            "children": [
              {
                "type": "text",
                "text": "verify the result with `page_list` and `nav_get`, then use navigation mutation tools when structure changes are needed"
              }
            ]
          }
        ]
      }
    ]
  }
}
