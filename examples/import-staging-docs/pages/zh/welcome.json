        "level": 1,
        "children": [
          {
            "type": "text",
            "text": "导入暂存示例"
          }
        ]
      },
      {
        "type": "paragraph",
        "id": "block-2",
        "children": [
          {
            "type": "text",
            "text": "这个样例专门展示 `import` 之后、`convert-import` 之前的工程状态。"
          }
        ]
      },
      {
        "type": "heading",
        "id": "block-3",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "适合什么场景"
          }
        ]
      },
      {
        "type": "list",
        "id": "block-4",
        "style": "bulleted",
        "items": [
          {
            "id": "element-4-item-1",
            "children": [
              {
                "type": "text",
                "text": "想检查 `imports/<importId>/manifest.json`"
              }
            ]
          },
          {
            "id": "element-5-item-1",
            "children": [
              {
                "type": "text",
                "text": "想理解 `items/*.json` 里保存了哪些字段"
              }
            ]
          },
          {
            "id": "element-6-item-1",
            "children": [
              {
                "type": "text",
                "text": "想演示暂存内容如何再转换为 canonical draft 页面"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "id": "block-7",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "这个样例包含什么"
          }
        ]
      },
      {
        "type": "list",
        "id": "block-8",
        "style": "bulleted",
        "items": [
          {
            "id": "element-8-item-1",
            "children": [
              {
                "type": "text",
                "text": "一份原始 Markdown：`legacy-docs/getting-started.md`"
              }
            ]
          },
          {
            "id": "element-9-item-1",
            "children": [
              {
                "type": "text",
                "text": "一份 staged manifest：`imports/legacy-2026-04-04-demo/manifest.json`"
              }
            ]
          },
          {
            "id": "element-10-item-1",
            "children": [
              {
                "type": "text",
                "text": "一份 staged item：`imports/legacy-2026-04-04-demo/items/getting-started.json`"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "id": "block-11",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "如何继续转换"
          }
        ]
      },
      {
        "type": "codeBlock",
        "id": "block-12",
        "language": "bash",
        "code": "node --experimental-strip-types packages/cli/src/index.ts convert-import legacy-2026-04-04-demo examples/import-staging-docs"
      },
      {
        "type": "paragraph",
        "id": "block-13",
        "children": [
          {
            "type": "text",
            "text": "仓库中的这个样例保留在转换前状态，方便直接检查暂存文件结构。"
          }
        ]
      }
    ]
  }
}
