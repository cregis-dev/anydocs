{
  "name": "anydocs",
  "version": "1.0.0",
  "private": true,
  "description": "Anydocs - AI-Era Documentation Platform",
  "scripts": {
    "dev": "pnpm --filter @anydocs/web dev",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @anydocs/web build",
    "build:desktop": "pnpm --filter @anydocs/desktop build",
    "build:cli": "pnpm --filter @anydocs/cli build",
    "build:mcp": "pnpm --filter @anydocs/mcp build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @anydocs/core test && pnpm --filter @anydocs/cli test && pnpm --filter @anydocs/mcp test",
    "test:e2e": "pnpm --filter @anydocs/web test:e2e",
    "test:e2e:p0": "pnpm --filter @anydocs/web test:e2e:p0",
    "test:acceptance": "pnpm test && pnpm --filter @anydocs/web test:e2e:p0",
    "test:web": "pnpm --filter @anydocs/web test",
    "test:full": "pnpm test && pnpm test:web"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
