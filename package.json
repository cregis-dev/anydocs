{
  "name": "anydocs",
  "version": "1.0.0",
  "private": true,
  "description": "Anydocs - AI-Era Documentation Platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/cregis-dev/anydocs"
  },
  "scripts": {
    "dev": "pnpm --filter @anydocs/web dev",
    "dev:web": "pnpm --filter @anydocs/web dev",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "dev:desktop-server": "pnpm --filter @anydocs/desktop-server dev",
    "dev:cli": "pnpm --filter @anydocs/cli dev",
    "dev:mcp": "pnpm --filter @anydocs/mcp dev",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @anydocs/core build",
    "build:cli": "pnpm --filter @anydocs/cli build",
    "build:mcp": "pnpm --filter @anydocs/mcp build",
    "build:web": "pnpm --filter @anydocs/web build",
    "build:web:docs": "pnpm --filter @anydocs/web docs:export",
    "build:web:desktop": "pnpm --filter @anydocs/web desktop:export",
    "build:desktop-server": "pnpm --filter @anydocs/desktop-server build",
    "build:desktop": "pnpm build:desktop:full",
    "build:desktop:full": "pnpm --filter @anydocs/web desktop:export && pnpm --filter @anydocs/cli build && pnpm --filter @anydocs/desktop-server build && pnpm --filter @anydocs/desktop tauri:build:app",
    "build:desktop:lite": "pnpm --filter @anydocs/web desktop:export && pnpm --filter @anydocs/desktop-server build && pnpm --filter @anydocs/desktop tauri:build:lite:app",
    "build:desktop:dmg": "pnpm build:desktop:dmg:full",
    "build:desktop:dmg:full": "pnpm --filter @anydocs/web desktop:export && pnpm --filter @anydocs/cli build && pnpm --filter @anydocs/desktop-server build && pnpm --filter @anydocs/desktop tauri:build:dmg",
    "build:desktop:dmg:lite": "pnpm --filter @anydocs/web desktop:export && pnpm --filter @anydocs/desktop-server build && pnpm --filter @anydocs/desktop tauri:build:lite:dmg",
    "build:desktop:release": "pnpm build:desktop:release:full",
    "build:desktop:release:full": "pnpm --filter @anydocs/web desktop:export && pnpm --filter @anydocs/cli build && pnpm --filter @anydocs/desktop-server build && pnpm --filter @anydocs/desktop tauri:build",
    "build:desktop:release:lite": "pnpm --filter @anydocs/web desktop:export && pnpm --filter @anydocs/desktop-server build && pnpm --filter @anydocs/desktop tauri:build:lite",
    "clean": "pnpm -r --if-present clean",
    "typecheck": "pnpm -r typecheck",
    "typecheck:core": "pnpm --filter @anydocs/core typecheck",
    "typecheck:cli": "pnpm --filter @anydocs/cli typecheck",
    "typecheck:mcp": "pnpm --filter @anydocs/mcp typecheck",
    "typecheck:web": "pnpm --filter @anydocs/web typecheck",
    "typecheck:desktop": "pnpm --filter @anydocs/desktop typecheck",
    "typecheck:desktop-server": "pnpm --filter @anydocs/desktop-server typecheck",
    "lint": "pnpm -r lint",
    "lint:web": "pnpm --filter @anydocs/web lint",
    "test": "pnpm --filter @anydocs/core test && pnpm --filter @anydocs/cli test && pnpm --filter @anydocs/mcp test",
    "test:core": "pnpm --filter @anydocs/core test",
    "test:cli": "pnpm --filter @anydocs/cli test",
    "test:cli:package": "pnpm --filter @anydocs/cli test:package",
    "test:mcp": "pnpm --filter @anydocs/mcp test",
    "test:web": "pnpm --filter @anydocs/web test",
    "test:web:p0": "pnpm --filter @anydocs/web test:p0",
    "test:web:p1": "pnpm --filter @anydocs/web test:e2e:p1",
    "test:web:api": "pnpm --filter @anydocs/web test:api",
    "test:web:ui": "pnpm --filter @anydocs/web test:ui",
    "test:e2e": "pnpm --filter @anydocs/web test:e2e",
    "test:e2e:p0": "pnpm --filter @anydocs/web test:e2e:p0",
    "test:acceptance": "pnpm test && pnpm --filter @anydocs/web test:e2e:p0",
    "test:full": "pnpm test && pnpm test:web",
    "cli": "pnpm --filter @anydocs/cli cli",
    "cli:init": "pnpm --filter @anydocs/cli cli init",
    "cli:build": "pnpm --filter @anydocs/cli cli build",
    "cli:preview": "pnpm --filter @anydocs/cli cli preview",
    "cli:studio": "pnpm --filter @anydocs/cli cli studio",
    "cli:import": "pnpm --filter @anydocs/cli cli import",
    "cli:convert-import": "pnpm --filter @anydocs/cli cli convert-import",
    "studio:starter": "pnpm cli:studio examples/starter-docs",
    "preview:starter": "pnpm cli:preview examples/starter-docs",
    "docs:starter": "pnpm cli:build examples/starter-docs",
    "release:npm": "node scripts/release-npm.mjs",
    "release:npm:dry-run": "node scripts/release-npm.mjs --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
